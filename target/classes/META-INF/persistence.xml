<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
	<persistence-unit name="MyEXE_JPA">
	<properties>
			<property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
			<property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/mydb_jpa1?createDatabaseIfNotExist=true"/>
			<property name="jakarta.persistence.jdbc.user" value="root"/>
			<property name="jakarta.persistence.jdbc.password" value="0_mysql_1"/>
			
			<!-- Consente di definire il processo di generazione delle tabelle del database -->
			<property name="hibernate.hbm2ddl.auto" value="update" />
			<!--  Definisce l'eventuale dialetto utilizzato dal Database -->
			<property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>			
			<!-- Mostra le operazioni SQL nel log -->
			<property name = "hibernate.show_sql" value = "true"/>
 
		</properties>
	</persistence-unit>
</persistence>
